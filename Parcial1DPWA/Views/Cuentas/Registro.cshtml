@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 card shadow p-4 border-0">
            <h3 class="text-center mb-4 text-success">Crear Nueva Cuenta</h3>

            <form asp-action="Registro" method="post">
                <div class="mb-3">
                    <label class="form-label">Nombre Completo</label>
                    <input name="nombre" type="text" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <input name="email" type="email" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input name="password" type="password" class="form-control" required />
                </div>

                <div class="mb-4">
                    <label class="form-label">Rol del Usuario</label>
                    <select name="rol" class="form-select">
                        <option value="Usuario">Usuario (Solo Consulta)</option>
                        <option value="Administrador">Administrador (Control Total)</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success w-100">Registrar y Entrar</button>
            </form>
        </div>
    </div>
</div>
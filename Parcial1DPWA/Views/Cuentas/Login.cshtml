@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 card shadow p-4 border-0">
            <h3 class="text-center mb-4 text-primary">📦 Small Box Login</h3>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <input name="email" type="email" class="form-control" placeholder="admin@smallbox.com" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input name="password" type="password" class="form-control" placeholder="****" required />
                </div>

                <button type="submit" class="btn btn-primary w-100 mt-2">Ingresar al Sistema</button>
            </form>

            <div class="mt-3 text-center">
                <p class="small">¿No tienes cuenta? <a asp-action="Registro">Regístrate aquí</a></p>
            </div>
        </div>
    </div>
</div>
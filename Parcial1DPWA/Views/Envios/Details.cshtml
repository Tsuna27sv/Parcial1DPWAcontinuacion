@model Parcial1DPWA.Models.Envio

@{
    ViewData["Title"] = "Detalles del Envío - Small Box";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Ficha de Envío #@Model.Id</h2>
            <span class="badge bg-light text-primary fs-5">@Model.EstadosEnvio.NombreEstado</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6 border-end">
                    <h5 class="text-muted"><i class="bi bi-person-fill"></i> Información de los Participantes</h5>
                    <hr />
                    <p><strong>Remitente (Cliente):</strong> @Model.Cliente.Nombre</p>
                    <p><strong>Destinatario:</strong> @Model.Destinatario.Nombre</p>
                    <p><strong>Departamento de Destino:</strong> @Model.DepartamentoDestino</p>
                </div>
                <div class="col-md-6">
                    <h5 class="text-muted"><i class="bi bi-box-seam"></i> Datos del Paquete y Costos</h5>
                    <hr />
                    <p><strong>ID del Paquete:</strong> @Model.PaqueteId</p>
                    <p><strong>Peso registrado:</strong> @Model.Paquete.Peso lb</p>
                    <p><strong>Fecha de Creación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="fs-4"><strong>Monto Total:</strong> <span class="text-success">$@Model.MontoTotal</span></p>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar Información</a>
            <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
        </div>
    </div>
</div>

@model IEnumerable<Parcial1DPWA.Models.Paquete>

@{
    ViewData["Title"] = "Listado de Paquetes - Small Box";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inventario de Paquetes</h1>
    <a asp-action="Create" class="btn btn-primary">➕ Registrar Nuevo Paquete</a>
</div>

<table class="table table-striped table-hover border">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Descripción del Contenido</th>
            <th>Peso (lb/kg)</th>
            <th>Estado de Asignación</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td class="fw-bold">
                    @Html.DisplayFor(modelItem => item.DescripcionContenido)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Peso) lb
                </td>
                <td>
                    @if (item.EnvioId != null)
                    {
                        <span class="badge bg-success">Asignado a Envío #@item.EnvioId</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente de Envío</span>
                    }
                </td>
                <td class="text-center">
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">Detalles</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Borrar</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

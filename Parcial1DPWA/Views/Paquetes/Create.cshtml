@model Parcial1DPWA.Models.Paquete

@{
    ViewData["Title"] = "Registrar Paquete";
}

<h1>Registrar Nuevo Paquete</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label class="control-label">¿Qué contiene el paquete?</label>
                <input asp-for="Descripcion" class="form-control" placeholder="Ej: Cámara, Ropa, Repuestos..." />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Peso" class="control-label">Peso (lb/kg)</label>
                <input asp-for="Peso" class="form-control" />
                <span asp-validation-for="Peso" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar Paquete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>